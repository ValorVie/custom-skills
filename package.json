{
  "name": "@valorvie/ai-dev",
  "version": "2.0.0",
  "description": "AI development workflow CLI toolkit",
  "type": "module",
  "bin": {
    "ai-dev": "./dist/cli.js"
  },
  "files": [
    "src/",
    "dist/",
    "skills/",
    "commands/",
    "agents/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile ./dist/cli.js --target bun",
    "prepublishOnly": "bun run build",
    "lint": "biome check src tests package.json tsconfig.json bunfig.toml biome.json",
    "format": "biome format --write src tests package.json tsconfig.json bunfig.toml biome.json",
    "test": "bun test",
    "snapshot:golden-parity": "bun run scripts/golden-parity/generate-cli-help-snapshots.ts",
    "test:golden-parity": "HOME=/tmp bun test tests/cli/golden-parity.test.ts tests/cli/non-help-golden-parity.test.ts",
    "parity:cycle": "bun run scripts/golden-parity/run-parity-cycle.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.3.0",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
