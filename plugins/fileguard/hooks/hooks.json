{
  "description": "FileGuard - Path-based access control for Claude Code",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/fileguard.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
